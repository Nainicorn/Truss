export default "<div class=\"__runDetail\">\n  {{#if loading}}\n    <div class=\"loading\">\n      <span class=\"spinner\"></span>\n      <span>Loading run details...</span>\n    </div>\n  {{else if error}}\n    <div class=\"error\">\n      <strong>Error:</strong> {{error}}\n    </div>\n  {{else if processingMessage}}\n    <div class=\"success\">\n      {{processingMessage}}\n    </div>\n  {{else}}\n    <!-- Header -->\n    <div class=\"__runDetail-header\">\n      <div class=\"__runDetail-header-content\">\n        <h1>Run Details</h1>\n        <div class=\"__runDetail-run-id-display\">{{runId}}</div>\n        <div class=\"__runDetail-metadata\">\n          {{#if (statusBadgeClass status)}}\n            <span class=\"badge {{statusBadgeClass status}}\">{{status}}</span>\n          {{else}}\n            <span>{{status}}</span>\n          {{/if}}\n        </div>\n        <div class=\"__runDetail-timestamps\">\n          <span class=\"__runDetail-metadata-item\">\n            <span class=\"__runDetail-metadata-label\">Created:</span>\n            <span class=\"__runDetail-metadata-value\">{{formatDate createdAt}}</span>\n          </span>\n          <span class=\"__runDetail-metadata-item\">\n            <span class=\"__runDetail-metadata-label\">Updated:</span>\n            <span class=\"__runDetail-metadata-value\">{{formatDate updatedAt}}</span>\n          </span>\n        </div>\n      </div>\n      <button class=\"btn btn-secondary btn-sm\" id=\"btn-back\">\n        ← Back to Runs\n      </button>\n    </div>\n\n    <!-- Decision Section -->\n    {{#if decision}}\n      <div class=\"__runDetail-decision\">\n        <div class=\"__runDetail-decision-header\">\n          <h2>Evaluation Decision</h2>\n          <span class=\"badge {{decisionBadgeClass decision.verdict}} __runDetail-verdict-badge\">\n            {{decision.verdict}}\n          </span>\n        </div>\n\n        <div class=\"__runDetail-decision-content\">\n          <p class=\"__runDetail-rationale\">\n            {{decision.rationale}}\n          </p>\n\n          {{#if decision.confidence}}\n            <div class=\"__runDetail-confidence-row\">\n              <span class=\"__runDetail-confidence-label\">Confidence Score:</span>\n              <div class=\"__runDetail-confidence-bar\">\n                <div class=\"__runDetail-confidence-fill\" style=\"width: {{decision.confidence}}%\"></div>\n              </div>\n              <span class=\"__runDetail-confidence-value\">{{decision.confidence}}</span>\n            </div>\n          {{/if}}\n\n          {{#if decision.revision_guidance}}\n            <div class=\"__runDetail-revision\">\n              <h3>Revision Guidance</h3>\n              <p>{{decision.revision_guidance}}</p>\n            </div>\n          {{/if}}\n        </div>\n      </div>\n    {{/if}}\n\n    <!-- Stats Table -->\n    {{#if probeResults}}\n      <div class=\"__runDetail-stats\">\n        <h2>Probe Results Summary</h2>\n        <div class=\"__runDetail-stats-container\">\n          <table class=\"__runDetail-stats-table\">\n            <thead>\n              <tr>\n                <th>Probe</th>\n                <th class=\"__runDetail-stats-cell\">Pass</th>\n                <th class=\"__runDetail-stats-cell\">Fail</th>\n                <th class=\"__runDetail-stats-cell\">Uncertain</th>\n                <th class=\"__runDetail-stats-cell\">Error</th>\n              </tr>\n            </thead>\n            <tbody>\n              {{#each probeResults}}\n                <tr>\n                  <td><strong>{{this.probe_id}}</strong></td>\n                  <td class=\"__runDetail-stats-cell {{#if (eq this.verdict \"PASS\")}}highlighted{{/if}}\">\n                    {{#if (eq this.verdict \"PASS\")}}✓{{/if}}\n                  </td>\n                  <td class=\"__runDetail-stats-cell {{#if (eq this.verdict \"FAIL\")}}highlighted{{/if}}\">\n                    {{#if (eq this.verdict \"FAIL\")}}✗{{/if}}\n                  </td>\n                  <td class=\"__runDetail-stats-cell {{#if (eq this.verdict \"UNCERTAIN\")}}highlighted{{/if}}\">\n                    {{#if (eq this.verdict \"UNCERTAIN\")}}?{{/if}}\n                  </td>\n                  <td class=\"__runDetail-stats-cell {{#if (eq this.verdict \"ERROR\")}}highlighted{{/if}}\">\n                    {{#if (eq this.verdict \"ERROR\")}}!{{/if}}\n                  </td>\n                </tr>\n              {{/each}}\n            </tbody>\n          </table>\n        </div>\n      </div>\n    {{/if}}\n\n    <!-- Probe Details Section -->\n    {{#if probeResults}}\n      <div class=\"__runDetail-probes\">\n        <div class=\"__runDetail-probes-header\">\n          <h2>Detailed Probe Analysis</h2>\n          <div class=\"__runDetail-probes-summary\">\n            <span class=\"__runDetail-summary-badge\">{{probeResults.length}} Probes</span>\n          </div>\n        </div>\n\n        <div class=\"__runDetail-accordion\">\n          {{#each probeResults}}\n            <div class=\"__runDetail-accordion-item\" data-probe-id=\"{{this.probe_id}}\">\n              <button class=\"__runDetail-accordion-header\">\n                <span class=\"__runDetail-accordion-icon rotated\">▶</span>\n                <div class=\"__runDetail-probe-header-content\">\n                  <strong class=\"__runDetail-probe-title\">{{this.probe_id}}</strong>\n                  <span class=\"badge {{verdictBadgeClass this.verdict}}\">\n                    {{this.verdict}}\n                  </span>\n                  {{#if this.confidence}}\n                    <span class=\"__runDetail-probe-confidence\">\n                      {{this.confidence}}\n                    </span>\n                  {{/if}}\n                </div>\n              </button>\n\n              <div class=\"__runDetail-accordion-content\" style=\"display: block;\">\n                <!-- Probe metadata section -->\n                {{#if this.description}}\n                  <div class=\"__runDetail-probe-metadata\">\n                    <span class=\"__runDetail-probe-metadata-label\">Description:</span>\n                    <span class=\"__runDetail-probe-metadata-value\">{{this.description}}</span>\n                  </div>\n                {{/if}}\n\n                {{#if this.reasoning}}\n                  <div class=\"__runDetail-probe-metadata\">\n                    <span class=\"__runDetail-probe-metadata-label\">Reasoning:</span>\n                    <span class=\"__runDetail-probe-metadata-value\">{{this.reasoning}}</span>\n                  </div>\n                {{/if}}\n\n                {{#if this.expected_checks}}\n                  <div class=\"__runDetail-probe-metadata\">\n                    <span class=\"__runDetail-probe-metadata-label\">Expected Checks:</span>\n                    <ul class=\"__runDetail-checks-list-inline\">\n                      {{#each this.expected_checks}}\n                        <li>{{this}}</li>\n                      {{/each}}\n                    </ul>\n                  </div>\n                {{/if}}\n\n                <!-- Evidence blocks -->\n                {{#if this.evidence}}\n                  <div class=\"__runDetail-probe-section\">\n                    <h4 class=\"__runDetail-section-title\">Evidence</h4>\n                    <div class=\"__runDetail-evidence-list\">\n                      {{#each this.evidence}}\n                        <div class=\"__runDetail-evidence-block\">\n                          <div class=\"__runDetail-evidence-header\">\n                            <span class=\"__runDetail-evidence-source\">{{this.source}}</span>\n                            {{#if this.locator}}\n                              <span class=\"__runDetail-evidence-locator\">{{this.locator}}</span>\n                            {{/if}}\n                          </div>\n                          {{#if this.excerpt}}\n                            <pre class=\"__runDetail-evidence-content\"><code>{{this.excerpt}}</code></pre>\n                          {{/if}}\n                        </div>\n                      {{/each}}\n                    </div>\n                  </div>\n                {{/if}}\n\n                <!-- Failure labels -->\n                {{#if this.failure_labels}}\n                  <div class=\"__runDetail-probe-metadata\">\n                    <span class=\"__runDetail-probe-metadata-label\">Failure Classifications:</span>\n                    <div class=\"__runDetail-labels-list-inline\">\n                      {{#each this.failure_labels}}\n                        <span class=\"badge badge-danger\">{{this}}</span>\n                      {{/each}}\n                    </div>\n                  </div>\n                {{/if}}\n              </div>\n            </div>\n          {{/each}}\n        </div>\n      </div>\n    {{/if}}\n\n    <!-- Task Spec Section (Collapsible) -->\n    {{#if taskSpec}}\n      <div class=\"__runDetail-section\">\n        <button class=\"__runDetail-section-toggle\" id=\"btn-toggle-task-spec\">\n          <span class=\"__runDetail-section-icon rotated\">▶</span>\n          <strong>Task Specification</strong>\n        </button>\n\n        <div class=\"__runDetail-section-content\" id=\"task-spec-content\" style=\"display: block;\">\n          <pre class=\"__runDetail-code\"><code>{{jsonStringify taskSpec}}</code></pre>\n        </div>\n      </div>\n    {{/if}}\n\n    <!-- Candidate Output Section (Collapsible) -->\n    {{#if candidateOutput}}\n      <div class=\"__runDetail-section\">\n        <button class=\"__runDetail-section-toggle\" id=\"btn-toggle-candidate\">\n          <span class=\"__runDetail-section-icon rotated\">▶</span>\n          <strong>Candidate Output</strong>\n        </button>\n\n        <div class=\"__runDetail-section-content\" id=\"candidate-output-content\" style=\"display: block;\">\n          <pre class=\"__runDetail-code\"><code>{{jsonStringify candidateOutput}}</code></pre>\n        </div>\n      </div>\n    {{/if}}\n\n    <!-- Audit Trace Section (Collapsible) -->\n    {{#if auditTrace}}\n      <div class=\"__runDetail-section\">\n        <button class=\"__runDetail-section-toggle\" id=\"btn-toggle-audit-trace\">\n          <span class=\"__runDetail-section-icon rotated\">▶</span>\n          <strong>Audit Trace</strong>\n        </button>\n\n        <div class=\"__runDetail-section-content\" id=\"audit-trace-content\" style=\"display: block;\">\n          <pre class=\"__runDetail-code\"><code>{{jsonStringify auditTrace}}</code></pre>\n        </div>\n      </div>\n    {{/if}}\n\n  {{/if}}\n</div>\n"