export default "<div class=\"__runsList\">\n  <div class=\"__runsList-header\">\n    <h1>Runs</h1>\n    <button class=\"btn btn-primary btn-sm\" id=\"btn-create-run\">\n      + Create New Run\n    </button>\n  </div>\n\n  <!-- Create Run Form Modal -->\n  <div class=\"__runsList-modal\" id=\"create-run-modal\" style=\"display: none;\">\n    <div class=\"__runsList-modal-content\">\n      <div class=\"__runsList-modal-header\">\n        <h2>Create New Run</h2>\n        <button class=\"__runsList-modal-close\" id=\"btn-close-modal\">&times;</button>\n      </div>\n\n      <form id=\"create-run-form\" class=\"__runsList-form\">\n        <!-- Task ID -->\n        <div class=\"__runsList-form-group\">\n          <label for=\"task-id\">Task ID *</label>\n          <input\n            type=\"text\"\n            id=\"task-id\"\n            name=\"task_id\"\n            class=\"__runsList-form-input\"\n            placeholder=\"e.g., task_summarization_001\"\n            required\n          />\n          <small>Unique identifier for this task</small>\n        </div>\n\n        <!-- Description -->\n        <div class=\"__runsList-form-group\">\n          <label for=\"task-description\">Description *</label>\n          <textarea\n            id=\"task-description\"\n            name=\"description\"\n            class=\"__runsList-form-textarea\"\n            placeholder=\"e.g., Summarize the provided article in 2-3 sentences\"\n            rows=\"3\"\n            required\n          ></textarea>\n          <small>What does the candidate need to do?</small>\n        </div>\n\n        <!-- Constraints -->\n        <div class=\"__runsList-form-group\">\n          <label for=\"task-constraints\">Constraints</label>\n          <textarea\n            id=\"task-constraints\"\n            name=\"constraints\"\n            class=\"__runsList-form-textarea\"\n            placeholder=\"e.g., Must be under 100 words\nMust not contain names\nMust maintain neutral tone\"\n            rows=\"2\"\n          ></textarea>\n          <small>One constraint per line (optional)</small>\n        </div>\n\n        <!-- Allowed Tools -->\n        <div class=\"__runsList-form-group\">\n          <label for=\"task-tools\">Allowed Tools</label>\n          <textarea\n            id=\"task-tools\"\n            name=\"allowed_tools\"\n            class=\"__runsList-form-textarea\"\n            placeholder=\"e.g., web_search\npdf_reader\ncalculator\"\n            rows=\"2\"\n          ></textarea>\n          <small>One tool per line. Leave empty to allow all tools (optional)</small>\n        </div>\n\n        <!-- Domain Tags -->\n        <div class=\"__runsList-form-group\">\n          <label for=\"task-tags\">Domain Tags</label>\n          <input\n            type=\"text\"\n            id=\"task-tags\"\n            name=\"domain_tags\"\n            class=\"__runsList-form-input\"\n            placeholder=\"e.g., medical, finance, legal (comma-separated)\"\n          />\n          <small>For categorization (optional)</small>\n        </div>\n\n        <!-- Rubric ID -->\n        <div class=\"__runsList-form-group\">\n          <label for=\"rubric-id\">Rubric ID</label>\n          <input\n            type=\"text\"\n            id=\"rubric-id\"\n            name=\"rubric_id\"\n            class=\"__runsList-form-input\"\n            placeholder=\"e.g., rubric_standard_eval\"\n          />\n          <small>Reference to evaluation rubric. Leave empty to auto-generate (optional)</small>\n        </div>\n\n        <hr style=\"margin: var(--spacing-16) 0; border: none; border-top: 1px solid var(--border);\" />\n\n        <!-- Candidate ID -->\n        <div class=\"__runsList-form-group\">\n          <label for=\"candidate-id\">Candidate ID *</label>\n          <input\n            type=\"text\"\n            id=\"candidate-id\"\n            name=\"candidate_id\"\n            class=\"__runsList-form-input\"\n            placeholder=\"e.g., gpt4_v1, claude_opus, user_submission\"\n            required\n          />\n          <small>Identifier for the model/agent producing the output</small>\n        </div>\n\n        <!-- Content -->\n        <div class=\"__runsList-form-group\">\n          <label for=\"candidate-content\">Response Content *</label>\n          <textarea\n            id=\"candidate-content\"\n            name=\"content\"\n            class=\"__runsList-form-textarea\"\n            placeholder=\"e.g., The article discusses climate change mitigation strategies, focusing on renewable energy adoption and policy frameworks needed for global coordination.\"\n            rows=\"4\"\n            required\n          ></textarea>\n          <small>The actual response/output from the candidate</small>\n        </div>\n\n        <!-- Form Actions -->\n        <div class=\"__runsList-form-actions\">\n          <button type=\"button\" class=\"btn btn-secondary\" id=\"btn-cancel-form\">\n            Cancel\n          </button>\n          <button type=\"submit\" class=\"btn btn-primary\" id=\"btn-submit-form\">\n            Create Run\n          </button>\n        </div>\n      </form>\n    </div>\n  </div>\n\n  {{#if loading}}\n    <div class=\"loading\">\n      <span class=\"spinner\"></span>\n      <span>Loading runs...</span>\n    </div>\n  {{else if error}}\n    <div class=\"error\">\n      <strong>Error:</strong> {{error}}\n    </div>\n  {{else}}\n    <!-- Runs Table -->\n    {{#if runs.length}}\n      <div class=\"__runsList-table-container\">\n        <table class=\"__runsList-table\">\n          <thead>\n            <tr>\n              <th>Run ID</th>\n              <th>Status</th>\n              <th>Decision</th>\n            </tr>\n          </thead>\n          <tbody>\n            {{#each runs}}\n              <tr class=\"__runsList-row\" data-run-id=\"{{this.run_id}}\">\n                <td class=\"__runsList-run-id\">\n                  <code>{{this.run_id}}</code>\n                </td>\n                <td>\n                  <span class=\"badge {{statusBadgeClass this.status}}\">\n                    {{this.status}}\n                  </span>\n                </td>\n                <td>\n                  {{#if this.run_record.decision}}\n                    <span class=\"badge {{decisionBadgeClass this.run_record.decision.verdict}}\">\n                      {{this.run_record.decision.verdict}}\n                    </span>\n                  {{else}}\n                    <span class=\"badge badge-gray\">Pending</span>\n                  {{/if}}\n                </td>\n              </tr>\n            {{/each}}\n          </tbody>\n        </table>\n      </div>\n\n      <!-- Infinite scroll sentinel -->\n      <div class=\"__runsList-sentinel\" id=\"scroll-sentinel\"></div>\n\n      <!-- Loading indicator for more runs -->\n      <div class=\"__runsList-loading-more\" id=\"loading-more\" style=\"display: none;\">\n        <span class=\"spinner\"></span>\n        <span>Loading more runs...</span>\n      </div>\n    {{else}}\n      <div class=\"error\" style=\"text-align: center;\">\n        <p>No runs found</p>\n      </div>\n    {{/if}}\n  {{/if}}\n</div>\n"