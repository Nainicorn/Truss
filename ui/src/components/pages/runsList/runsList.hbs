<div class="__runsList">
  <div class="__runsList-header">
    <h1>Runs</h1>
    <button class="btn btn-primary btn-sm" id="btn-create-run">
      + Create New Run
    </button>
  </div>

  <!-- Create Run Form Modal -->
  <div class="__runsList-modal" id="create-run-modal" style="display: none;">
    <div class="__runsList-modal-content">
      <div class="__runsList-modal-header">
        <h2>Create New Run</h2>
        <button class="__runsList-modal-close" id="btn-close-modal">&times;</button>
      </div>

      <form id="create-run-form" class="__runsList-form">
        <!-- Task ID -->
        <div class="__runsList-form-group">
          <label for="task-id">Task ID *</label>
          <input
            type="text"
            id="task-id"
            name="task_id"
            class="__runsList-form-input"
            placeholder="e.g., task_summarization_001"
            required
          />
          <small>Unique identifier for this task</small>
        </div>

        <!-- Description -->
        <div class="__runsList-form-group">
          <label for="task-description">Description *</label>
          <textarea
            id="task-description"
            name="description"
            class="__runsList-form-textarea"
            placeholder="e.g., Summarize the provided article in 2-3 sentences"
            rows="3"
            required
          ></textarea>
          <small>What does the candidate need to do?</small>
        </div>

        <!-- Constraints -->
        <div class="__runsList-form-group">
          <label for="task-constraints">Constraints</label>
          <textarea
            id="task-constraints"
            name="constraints"
            class="__runsList-form-textarea"
            placeholder="e.g., Must be under 100 words
Must not contain names
Must maintain neutral tone"
            rows="2"
          ></textarea>
          <small>One constraint per line (optional)</small>
        </div>

        <!-- Allowed Tools -->
        <div class="__runsList-form-group">
          <label for="task-tools">Allowed Tools</label>
          <textarea
            id="task-tools"
            name="allowed_tools"
            class="__runsList-form-textarea"
            placeholder="e.g., web_search
pdf_reader
calculator"
            rows="2"
          ></textarea>
          <small>One tool per line. Leave empty to allow all tools (optional)</small>
        </div>

        <!-- Domain Tags -->
        <div class="__runsList-form-group">
          <label for="task-tags">Domain Tags</label>
          <input
            type="text"
            id="task-tags"
            name="domain_tags"
            class="__runsList-form-input"
            placeholder="e.g., medical, finance, legal (comma-separated)"
          />
          <small>For categorization (optional)</small>
        </div>

        <!-- Rubric ID -->
        <div class="__runsList-form-group">
          <label for="rubric-id">Rubric ID</label>
          <input
            type="text"
            id="rubric-id"
            name="rubric_id"
            class="__runsList-form-input"
            placeholder="e.g., rubric_standard_eval"
          />
          <small>Reference to evaluation rubric. Leave empty to auto-generate (optional)</small>
        </div>

        <hr style="margin: var(--spacing-16) 0; border: none; border-top: 1px solid var(--border);" />

        <!-- Candidate ID -->
        <div class="__runsList-form-group">
          <label for="candidate-id">Candidate ID *</label>
          <input
            type="text"
            id="candidate-id"
            name="candidate_id"
            class="__runsList-form-input"
            placeholder="e.g., gpt4_v1, claude_opus, user_submission"
            required
          />
          <small>Identifier for the model/agent producing the output</small>
        </div>

        <!-- Content -->
        <div class="__runsList-form-group">
          <label for="candidate-content">Response Content *</label>
          <textarea
            id="candidate-content"
            name="content"
            class="__runsList-form-textarea"
            placeholder="e.g., The article discusses climate change mitigation strategies, focusing on renewable energy adoption and policy frameworks needed for global coordination."
            rows="4"
            required
          ></textarea>
          <small>The actual response/output from the candidate</small>
        </div>

        <!-- Form Actions -->
        <div class="__runsList-form-actions">
          <button type="button" class="btn btn-secondary" id="btn-cancel-form">
            Cancel
          </button>
          <button type="submit" class="btn btn-primary" id="btn-submit-form">
            Create Run
          </button>
        </div>
      </form>
    </div>
  </div>

  {{#if loading}}
    <div class="loading">
      <span class="spinner"></span>
      <span>Loading runs...</span>
    </div>
  {{else if error}}
    <div class="error">
      <strong>Error:</strong> {{error}}
    </div>
  {{else}}
    <!-- Runs Table -->
    {{#if runs.length}}
      <div class="__runsList-table-container">
        <table class="__runsList-table">
          <thead>
            <tr>
              <th>Task ID</th>
              <th>Run ID</th>
              <th>Status</th>
              <th>Decision</th>
            </tr>
          </thead>
          <tbody>
            {{#each runs}}
              <tr class="__runsList-row" data-run-id="{{this.run_id}}">
                <td class="__runsList-task-id">
                  {{this.task_spec.task_id}}
                </td>
                <td class="__runsList-run-id">
                  <code>{{this.run_id}}</code>
                </td>
                <td>
                  <span class="badge {{statusBadgeClass this.status}}">
                    {{this.status}}
                  </span>
                </td>
                <td>
                  {{#if this.run_record.decision}}
                    <span class="badge {{decisionBadgeClass this.run_record.decision.verdict}}">
                      {{this.run_record.decision.verdict}}
                    </span>
                  {{else}}
                    <span class="badge badge-gray">Pending</span>
                  {{/if}}
                </td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      <!-- Infinite scroll sentinel -->
      <div class="__runsList-sentinel" id="scroll-sentinel"></div>

      <!-- Loading indicator for more runs -->
      <div class="__runsList-loading-more" id="loading-more" style="display: none;">
        <span class="spinner"></span>
        <span>Loading more runs...</span>
      </div>
    {{else}}
      <div class="error" style="text-align: center;">
        <p>No runs found</p>
      </div>
    {{/if}}
  {{/if}}
</div>
