<div class="__runDetail">
  <!-- Breadcrumb -->
  <div class="__runDetail-breadcrumb">
    <a href="#" id="btn-back-runs">Runs</a>
    <span>&gt;</span>
    <span>{{runId}}</span>
  </div>

  {{#if loading}}
    <div class="loading">
      <span class="spinner"></span>
      <span>Loading run details...</span>
    </div>
  {{else if error}}
    <div class="error">
      <strong>Error:</strong> {{error}}
    </div>
  {{else if processingMessage}}
    <div class="success">
      {{processingMessage}}
    </div>
  {{else}}
    <!-- Header -->
    <div class="__runDetail-header">
      <div>
        <h1>Run {{runId}}</h1>
        <div class="__runDetail-metadata">
          <span class="badge {{statusBadgeClass status}}">{{status}}</span>
          <span class="__runDetail-timestamp">Created: {{formatDate createdAt}}</span>
          <span class="__runDetail-timestamp">Updated: {{formatDate updatedAt}}</span>
        </div>
      </div>
      <button class="btn btn-primary btn-sm" id="btn-download-report">
        📥 Download Report
      </button>
    </div>

    <!-- Decision Section -->
    {{#if decision}}
      <div class="__runDetail-decision">
        <h2>Decision</h2>
        <div class="__runDetail-decision-content">
          <div class="__runDetail-decision-verdict">
            <span class="badge {{decisionBadgeClass decision.verdict}} __runDetail-verdict-badge">
              {{decision.verdict}}
            </span>
            {{#if decision.confidence}}
              <span class="__runDetail-confidence">
                Confidence: {{decision.confidence}}
              </span>
            {{/if}}
          </div>

          <p class="__runDetail-rationale">
            {{decision.rationale}}
          </p>

          {{#if decision.revision_guidance}}
            <div class="__runDetail-revision">
              <h3>Revision Guidance</h3>
              <p>{{decision.revision_guidance}}</p>
            </div>
          {{/if}}
        </div>
      </div>
    {{/if}}

    <!-- Stats Table -->
    {{#if probeResults}}
      <div class="__runDetail-stats">
        <h2>Probe Results Summary</h2>
        <div class="__runDetail-stats-container">
          <table class="__runDetail-stats-table">
            <thead>
              <tr>
                <th>Probe</th>
                <th class="__runDetail-stats-cell">
                  <span class="__runDetail-verdict-icon pass">✓</span> Pass
                </th>
                <th class="__runDetail-stats-cell">
                  <span class="__runDetail-verdict-icon fail">✗</span> Fail
                </th>
                <th class="__runDetail-stats-cell">
                  <span class="__runDetail-verdict-icon uncertain">?</span> Uncertain
                </th>
                <th class="__runDetail-stats-cell">
                  <span class="__runDetail-verdict-icon error">!</span> Error
                </th>
              </tr>
            </thead>
            <tbody>
              {{#each probeResults}}
                <tr>
                  <td><strong>{{this.probe_id}}</strong></td>
                  <td class="__runDetail-stats-cell {{#if (eq this.verdict "PASS")}}highlighted{{/if}}">
                    {{#if (eq this.verdict "PASS")}}✓{{/if}}
                  </td>
                  <td class="__runDetail-stats-cell {{#if (eq this.verdict "FAIL")}}highlighted{{/if}}">
                    {{#if (eq this.verdict "FAIL")}}✗{{/if}}
                  </td>
                  <td class="__runDetail-stats-cell {{#if (eq this.verdict "UNCERTAIN")}}highlighted{{/if}}">
                    {{#if (eq this.verdict "UNCERTAIN")}}?{{/if}}
                  </td>
                  <td class="__runDetail-stats-cell {{#if (eq this.verdict "ERROR")}}highlighted{{/if}}">
                    {{#if (eq this.verdict "ERROR")}}!{{/if}}
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    {{/if}}

    <!-- Probe Accordion -->
    {{#if probeResults}}
      <div class="__runDetail-probes">
        <div class="__runDetail-probes-header">
          <h2>Probe Details</h2>
          <button class="btn btn-secondary btn-sm" id="btn-collapse-all">
            Collapse All
          </button>
        </div>

        <div class="__runDetail-accordion">
          {{#each probeResults}}
            <div class="__runDetail-accordion-item" data-probe-id="{{this.probe_id}}">
              <button class="__runDetail-accordion-header">
                <span class="__runDetail-accordion-icon">▶</span>
                <strong>{{this.probe_id}}</strong>
                <span class="badge {{verdictBadgeClass this.verdict}}">
                  {{this.verdict}}
                </span>
                {{#if this.confidence}}
                  <span class="__runDetail-probe-confidence">
                    {{this.confidence}}
                  </span>
                {{/if}}
              </button>

              <div class="__runDetail-accordion-content" style="display: none;">
                <!-- Probe metadata -->
                <div class="__runDetail-probe-meta">
                  <div class="__runDetail-meta-row">
                    <span class="__runDetail-meta-label">Description:</span>
                    <span>{{this.description}}</span>
                  </div>
                  {{#if this.reasoning}}
                    <div class="__runDetail-meta-row">
                      <span class="__runDetail-meta-label">Reasoning:</span>
                      <span>{{this.reasoning}}</span>
                    </div>
                  {{/if}}
                  {{#if this.expected_checks}}
                    <div class="__runDetail-meta-row">
                      <span class="__runDetail-meta-label">Expected Checks:</span>
                      <ul>
                        {{#each this.expected_checks}}
                          <li>{{this}}</li>
                        {{/each}}
                      </ul>
                    </div>
                  {{/if}}
                </div>

                <!-- Evidence blocks -->
                {{#if this.evidence}}
                  <div class="__runDetail-evidence">
                    <h4>Evidence</h4>
                    {{#each this.evidence}}
                      <div class="__runDetail-evidence-block">
                        <div class="__runDetail-evidence-header">
                          <span class="__runDetail-evidence-source">{{this.source}}</span>
                          {{#if this.locator}}
                            <span class="__runDetail-evidence-locator">{{this.locator}}</span>
                          {{/if}}
                        </div>
                        {{#if this.excerpt}}
                          <pre class="__runDetail-evidence-content"><code>{{this.excerpt}}</code></pre>
                        {{/if}}
                      </div>
                    {{/each}}
                  </div>
                {{/if}}

                <!-- Failure labels -->
                {{#if this.failure_labels}}
                  <div class="__runDetail-failure-labels">
                    <h4>Failure Labels</h4>
                    <div class="__runDetail-labels-list">
                      {{#each this.failure_labels}}
                        <span class="badge badge-danger">{{this}}</span>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}
              </div>
            </div>
          {{/each}}
        </div>
      </div>
    {{/if}}

    <!-- Task Spec Section (Collapsible) -->
    {{#if taskSpec}}
      <div class="__runDetail-section">
        <button class="__runDetail-section-toggle" id="btn-toggle-task-spec">
          <span class="__runDetail-section-icon">▶</span>
          <strong>Task Specification</strong>
        </button>

        <div class="__runDetail-section-content" id="task-spec-content" style="display: none;">
          <pre class="__runDetail-code"><code>{{jsonStringify taskSpec}}</code></pre>
        </div>
      </div>
    {{/if}}

    <!-- Candidate Output Section (Collapsible) -->
    {{#if candidateOutput}}
      <div class="__runDetail-section">
        <button class="__runDetail-section-toggle" id="btn-toggle-candidate">
          <span class="__runDetail-section-icon">▶</span>
          <strong>Candidate Output</strong>
        </button>

        <div class="__runDetail-section-content" id="candidate-output-content" style="display: none;">
          <pre class="__runDetail-code"><code>{{jsonStringify candidateOutput}}</code></pre>
        </div>
      </div>
    {{/if}}

    <!-- Audit Trace Section (Collapsible) -->
    {{#if auditTrace}}
      <div class="__runDetail-section">
        <button class="__runDetail-section-toggle" id="btn-toggle-audit-trace">
          <span class="__runDetail-section-icon">▶</span>
          <strong>Audit Trace</strong>
        </button>

        <div class="__runDetail-section-content" id="audit-trace-content" style="display: none;">
          <pre class="__runDetail-code"><code>{{jsonStringify auditTrace}}</code></pre>
        </div>
      </div>
    {{/if}}

    <!-- Back Button -->
    <div class="__runDetail-footer">
      <button class="btn btn-secondary" id="btn-back">
        ← Back to Runs
      </button>
    </div>
  {{/if}}
</div>
