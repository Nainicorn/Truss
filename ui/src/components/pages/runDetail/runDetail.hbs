<div class="__runDetail">
  {{#if loading}}
    <div class="loading">
      <span class="spinner"></span>
      <span>Loading run details...</span>
    </div>
  {{else if error}}
    <div class="error">
      <strong>Error:</strong> {{error}}
    </div>
  {{else if processingMessage}}
    <div class="success">
      {{processingMessage}}
    </div>
  {{else}}
    <!-- Header -->
    <div class="__runDetail-header">
      <div class="__runDetail-header-content">
        <h1>Run Details</h1>
        <div class="__runDetail-run-id-display">{{runId}}</div>
        <div class="__runDetail-metadata">
          {{#if (statusBadgeClass status)}}
            <span class="badge {{statusBadgeClass status}}">{{status}}</span>
          {{else}}
            <span>{{status}}</span>
          {{/if}}
        </div>
        <div class="__runDetail-timestamps">
          <span class="__runDetail-metadata-item">
            <span class="__runDetail-metadata-label">Created:</span>
            <span class="__runDetail-metadata-value">{{formatDate createdAt}}</span>
          </span>
          <span class="__runDetail-metadata-item">
            <span class="__runDetail-metadata-label">Updated:</span>
            <span class="__runDetail-metadata-value">{{formatDate updatedAt}}</span>
          </span>
        </div>
      </div>
      <button class="btn btn-secondary btn-sm" id="btn-back">
        ← Back to Runs
      </button>
    </div>

    <!-- Decision Section -->
    {{#if decision}}
      <div class="__runDetail-decision">
        <div class="__runDetail-decision-header">
          <h2>Evaluation Decision</h2>
          <span class="badge {{decisionBadgeClass decision.verdict}} __runDetail-verdict-badge">
            {{decision.verdict}}
          </span>
        </div>

        <div class="__runDetail-decision-content">
          {{#if decision.confidence}}
            <div class="__runDetail-confidence-row">
              <span class="__runDetail-confidence-label">Confidence Score:</span>
              <div class="__runDetail-confidence-bar">
                <div class="__runDetail-confidence-fill" style="width: {{decision.confidence}}%"></div>
              </div>
              <span class="__runDetail-confidence-value">{{decision.confidence}}</span>
            </div>
          {{/if}}

          {{#if decision.revision_guidance}}
            <div class="__runDetail-revision">
              <h3>Revision Guidance</h3>
              <p>{{decision.revision_guidance}}</p>
            </div>
          {{/if}}
        </div>
      </div>
    {{/if}}

    <!-- Stats Table -->
    {{#if probeResults}}
      <div class="__runDetail-stats">
        <h2>Probe Results Summary</h2>
        <div class="__runDetail-stats-container">
          <table class="__runDetail-stats-table">
            <thead>
              <tr>
                <th>Probe</th>
                <th class="__runDetail-stats-cell">Pass</th>
                <th class="__runDetail-stats-cell">Fail</th>
                <th class="__runDetail-stats-cell">Uncertain</th>
                <th class="__runDetail-stats-cell">Error</th>
              </tr>
            </thead>
            <tbody>
              {{#each probeResults}}
                <tr>
                  <td><strong>{{this.probe_id}}</strong></td>
                  <td class="__runDetail-stats-cell {{#if (eq this.verdict "PASS")}}highlighted{{/if}}">
                    {{#if (eq this.verdict "PASS")}}✓{{/if}}
                  </td>
                  <td class="__runDetail-stats-cell {{#if (eq this.verdict "FAIL")}}highlighted{{/if}}">
                    {{#if (eq this.verdict "FAIL")}}✗{{/if}}
                  </td>
                  <td class="__runDetail-stats-cell {{#if (eq this.verdict "UNCERTAIN")}}highlighted{{/if}}">
                    {{#if (eq this.verdict "UNCERTAIN")}}?{{/if}}
                  </td>
                  <td class="__runDetail-stats-cell {{#if (eq this.verdict "ERROR")}}highlighted{{/if}}">
                    {{#if (eq this.verdict "ERROR")}}!{{/if}}
                  </td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    {{/if}}

    <!-- Probe Details Section -->
    {{#if probeResults}}
      <div class="__runDetail-probes">
        <div class="__runDetail-probes-header">
          <h2>Detailed Probe Analysis</h2>
          <div class="__runDetail-probes-summary">
          </div>
        </div>

        <div class="__runDetail-accordion">
          {{#each probeResults}}
            <div class="__runDetail-accordion-item" data-probe-id="{{this.probe_id}}">
              <button class="__runDetail-accordion-header">
                <span class="__runDetail-accordion-icon rotated">▶</span>
                <div class="__runDetail-probe-header-content">
                  <strong class="__runDetail-probe-title">{{this.probe_id}}</strong>
                  <span class="badge {{verdictBadgeClass this.verdict}}">
                    {{this.verdict}}
                  </span>
                </div>
              </button>

              <div class="__runDetail-accordion-content" style="display: block;">
                <!-- Probe metadata section -->

                {{#if this.reasoning}}
                  <div class="__runDetail-probe-metadata">
                    <span class="__runDetail-probe-metadata-label">Reasoning:</span>
                    <span class="__runDetail-probe-metadata-value">{{this.reasoning}}</span>
                  </div>
                {{/if}}

                {{#if this.expected_checks}}
                  <div class="__runDetail-probe-metadata">
                    <span class="__runDetail-probe-metadata-label">Expected Checks:</span>
                    <ul class="__runDetail-checks-list-inline">
                      {{#each this.expected_checks}}
                        <li>{{this}}</li>
                      {{/each}}
                    </ul>
                  </div>
                {{/if}}

                <!-- Evidence blocks -->
                {{#if this.evidence}}
                  <div class="__runDetail-probe-section">
                    <h4 class="__runDetail-section-title">Evidence</h4>
                    <div class="__runDetail-evidence-list">
                      {{#each this.evidence}}
                        <div class="__runDetail-evidence-block">
                          <div class="__runDetail-evidence-header">
                            <span class="__runDetail-evidence-source">{{this.source}}</span>
                            {{#if this.locator}}
                              <span class="__runDetail-evidence-locator">{{this.locator}}</span>
                            {{/if}}
                          </div>
                          {{#if this.excerpt}}
                            <pre class="__runDetail-evidence-content"><code>{{this.excerpt}}</code></pre>
                          {{/if}}
                        </div>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}

                <!-- Failure labels -->
                {{#if this.failure_labels}}
                  <div class="__runDetail-probe-metadata">
                    <span class="__runDetail-probe-metadata-label">Failure Classifications:</span>
                    <div class="__runDetail-labels-list-inline">
                      {{#each this.failure_labels}}
                        <span class="badge badge-danger">{{this}}</span>
                      {{/each}}
                    </div>
                  </div>
                {{/if}}
              </div>
            </div>
          {{/each}}
        </div>
      </div>
    {{/if}}

    <!-- Task Spec Section (Collapsible) -->
    {{#if taskSpec}}
      <div class="__runDetail-section">
        <button class="__runDetail-section-toggle" id="btn-toggle-task-spec">
          <span class="__runDetail-section-icon rotated">▶</span>
          <strong>Task Specification</strong>
        </button>

        <div class="__runDetail-section-content" id="task-spec-content" style="display: block;">
          <pre class="__runDetail-code"><code>{{jsonStringify taskSpec}}</code></pre>
        </div>
      </div>
    {{/if}}

    <!-- Candidate Output Section (Collapsible) -->
    {{#if candidateOutput}}
      <div class="__runDetail-section">
        <button class="__runDetail-section-toggle" id="btn-toggle-candidate">
          <span class="__runDetail-section-icon rotated">▶</span>
          <strong>Candidate Output</strong>
        </button>

        <div class="__runDetail-section-content" id="candidate-output-content" style="display: block;">
          <pre class="__runDetail-code"><code>{{jsonStringify candidateOutput}}</code></pre>
        </div>
      </div>
    {{/if}}

    <!-- Audit Trace Section (Collapsible) -->
    {{#if auditTrace}}
      <div class="__runDetail-section">
        <button class="__runDetail-section-toggle" id="btn-toggle-audit-trace">
          <span class="__runDetail-section-icon rotated">▶</span>
          <strong>Audit Trace</strong>
        </button>

        <div class="__runDetail-section-content" id="audit-trace-content" style="display: block;">
          <pre class="__runDetail-code"><code>{{jsonStringify auditTrace}}</code></pre>
        </div>
      </div>
    {{/if}}

  {{/if}}
</div>
